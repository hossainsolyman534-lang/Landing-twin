{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Represents a dress in the inventory.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "integer" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name", "price", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "integer" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerPhone", "customerAddress", "productId", "quantity", "totalPrice", "status", "createdAt"]
    },
    "Content": {
      "title": "Content",
      "description": "Dynamic content for the landing page.",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "offerText": { "type": "string" },
        "offerPrice": { "type": "number" },
        "originalPrice": { "type": "number" }
      }
    },
    "User": {
      "title": "User",
      "description": "User profile and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products available for sale."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders."
    },
    "/content/landingPage": {
      "schema": "Content",
      "description": "Single document for landing page content."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles and roles."
    }
  }
}
